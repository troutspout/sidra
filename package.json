{
  "name": "sidra",
  "productName": "Sidra",
  "version": "0.3.5",
  "description": "An elegant Apple Music desktop client for Linux, macOS and Windows. No frippery, just quality. A better class of Cider 🍎",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc",
    "dist": "electron-builder",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Martin Wimpress <code@wimpress.io>",
  "homepage": "https://github.com/wimpysworld/sidra",
  "license": "BlueOak-1.0.0",
  "type": "commonjs",
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v42.3.3+wvcus",
    "electron-builder": "^26.15.5",
    "shx": "^0.4.0",
    "typescript": "^6.x",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@holusion/dbus-next": "^0.11.2",
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-conf": "^1.3.0",
    "electron-log": "^5.x",
    "electron-updater": "^6.8.9"
  },
  "overrides": {
    "brace-expansion": ">=5.0.6",
    "undici": "7.28.0"
  },
  "build": {
    "appId": "world.wimpys.sidra",
    "productName": "Sidra",
    "copyright": "Copyright (c) Martin Wimpress",
    "publish": {
      "provider": "github",
      "owner": "wimpysworld",
      "repo": "sidra"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "assets/icons/**",
      "assets/catppuccin.css",
      "assets/locales/about.json",
      "assets/locales/loading.json",
      "assets/locales/tray.json",
      "assets/locales/update.json",
      "assets/musicKitHook.js",
      "assets/navigationBar.js",
      "assets/about.html",
      "assets/authStyleFix.css",
      "assets/sidra-logo.png",
      "assets/splash.html",
      "assets/styleFix.css"
    ],
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!assets/source/**"
    ],
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "snap"
      ],
      "category": "Audio",
      "executableName": "sidra",
      "desktop": {
        "entry": {
          "Actions": "PlayPause;Next;Previous;Stop;",
          "MimeType": "x-scheme-handler/itms;"
        },
        "desktopActions": {
          "PlayPause": {
            "Name": "Play-Pause",
            "Name[de]": "Abspielen-Pausieren",
            "Exec": "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.sidra /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.PlayPause"
          },
          "Next": {
            "Name": "Next",
            "Name[de]": "Nächstes",
            "Exec": "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.sidra /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Next"
          },
          "Previous": {
            "Name": "Previous",
            "Name[de]": "Vorheriges",
            "Exec": "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.sidra /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Previous"
          },
          "Stop": {
            "Name": "Stop",
            "Name[de]": "Stop",
            "Exec": "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.sidra /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Stop"
          }
        }
      }
    },
    "protocols": [
      {
        "name": "Apple Music URL",
        "schemes": [
          "itms"
        ]
      }
    ],
    "appImage": {
      "artifactName": "${productName}-${os}-${arch}.${ext}"
    },
    "deb": {
      "maintainer": "Martin Wimpress <code@wimpress.io>",
      "priority": "optional"
    },
    "rpm": {
      "vendor": "Martin Wimpress"
    },
    "snapcraft": {
      "base": "core24",
      "core24": {
        "confinement": "strict",
        "grade": "stable",
        "summary": "An elegant Apple Music desktop client",
        "plugs": [
          "default",
          {
            "browser-support": {
              "interface": "browser-support",
              "allow-sandbox": true
            }
          },
          "removable-media"
        ],
        "slots": [
          {
            "mpris": {
              "name": "sidra"
            }
          }
        ],
        "environment": {
          "TMPDIR": "$XDG_RUNTIME_DIR"
        },
        "publish": false
      }
    },
    "afterPack": "build/afterPack.cjs",
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 140,
          "y": 150
        },
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 10000,
          "y": 10000,
          "path": ".background.tiff"
        },
        {
          "x": 10000,
          "y": 10000,
          "path": ".VolumeIcon.icns"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
